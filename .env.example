# Neo4j connection
TDAD_NEO4J_URI=bolt://localhost:7687
TDAD_NEO4J_USER=neo4j
TDAD_NEO4J_PASSWORD=password
TDAD_NEO4J_DATABASE=neo4j

# Optional: enable coverage-based test linking
TDAD_USE_COVERAGE=false
TDAD_COVERAGE_THRESHOLD=0.1

# Performance tuning
TDAD_INDEX_WORKERS=4
TDAD_QUERY_TIMEOUT=20.0
